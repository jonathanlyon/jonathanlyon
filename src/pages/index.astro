---
import BaseLayout from "../layouts/BaseLayout.astro";

const homeDescription =
  "Jonathan Lyon is a writer and photographer in Whangaripo Valley, building a cabin, writing The Narrative Witness and keeping a record of a life being made.";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Jonathan Lyon",
  url: "https://jonathanlyon.com/",
  image: "https://jonathanlyon.com/images/jonathan-portrait.jpg",
  jobTitle: "Writer and photographer",
  homeLocation: {
    "@type": "Place",
    name: "Whangaripo Valley, Aotearoa New Zealand",
  },
  sameAs: [
    "https://jonathanlyon.substack.com",
    "https://thenarrativewitness.com",
  ],
  knowsAbout: [
    "literary memoir",
    "photography",
    "adoption",
    "relinquishment",
    "identity",
    "memory",
    "writing",
  ],
  description: homeDescription,
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Jonathan Lyon",
  url: "https://jonathanlyon.com/",
  description: homeDescription,
  publisher: {
    "@type": "Person",
    name: "Jonathan Lyon",
  },
};
---

<BaseLayout
  description={homeDescription}
  image="/images/journal/reflected-self.jpg"
  imageAlt="Layered black and white self-portrait by Jonathan Lyon"
  imageWidth={2400}
  imageHeight={1599}
  type="profile"
  tags={["writer", "photographer", "memoir", "Whangaripo Valley", "The Narrative Witness"]}
  jsonLd={[personSchema, websiteSchema]}
  solidHeader
>
  <section class="profile-hero shell">
    <div class="profile-kicker">
      <p class="eyebrow">Writer · Photographer · Father · Maker</p>
    </div>
    <div class="profile-title">
      <h1 class="display">Jonathan Lyon</h1>
      <p>
        A few lives ago I was working in large advertising agencies in London
        and New York. Today, I live in Whangaripo Valley, where I am writing a book,
        building a cabin by hand, attempting to keep old machinery alive and
        trying to remain faithful to the life unfolding in front of me.
      </p>
      <div class="profile-actions">
        <a class="rule-link" href="https://thenarrativewitness.com">
          The Narrative Witness <span>↗</span>
        </a>
        <a class="rule-link" href="https://jonathanlyon.substack.com">
          Substack <span>↗</span>
        </a>
      </div>
    </div>
    <figure class="profile-portrait">
      <img
        src="/images/jonathan-portrait.jpg"
        alt="Black and white portrait of Jonathan Lyon"
      />
      <figcaption>
        <span>Current location</span>
        <strong>Whangaripo Valley, Aotearoa New Zealand</strong>
      </figcaption>
    </figure>
  </section>

  <section class="profile-statement">
    <div class="profile-statement-inner shell">
      <p class="eyebrow">The current shape</p>
      <blockquote>
        I am interested in the lives we assemble after the original map stops
        being useful.
      </blockquote>
      <p>
        Writing, photography, fatherhood, land, bread, machinery, weather,
        memory and the slow construction of shelter. Not separate identities so
        much as different doors into the same attempt: to become more fully
        present for the life I have.
      </p>
    </div>
  </section>

  <section class="profile-now shell" id="about">
    <div class="section-head">
      <p class="eyebrow">At present</p>
      <h2 class="display">The many hats, mostly literal.</h2>
    </div>
    <div class="profile-now-grid">
      <article>
        <span>01</span>
        <h3>Writing</h3>
        <p>
          I am developing <em>The Narrative Witness</em>, a literary memoir
          project exploring adoption, relinquishment, identity, memory and
          authorship.
        </p>
      </article>
      <article>
        <span>02</span>
        <h3>Making</h3>
        <p>
          I am building a cabin by hand, learning from timber, water, mud,
          mistakes and the small honesty of work that leaves evidence.
        </p>
      </article>
      <article>
        <span>03</span>
        <h3><a href="/journal/the-shape-of-waiting/">Photography</a></h3>
        <p>
          I keep a black-and-white visual record of landscapes, thresholds,
          weather, traces and the quiet structures that seem to wait for us.
        </p>
      </article>
      <article>
        <span>04</span>
        <h3>Life</h3>
        <p>
          Walking with my daughter, baking bread, hauling water from the creek
          and trying, imperfectly and daily, to become more myself.
        </p>
      </article>
    </div>
  </section>

  <section class="profile-image-band" id="photography">
    <img
      src="/images/journal/still-water.jpg"
      alt="Mountains and clouds reflected in still lake water"
      loading="lazy"
    />
    <div class="profile-image-copy shell">
      <p class="eyebrow">Photography</p>
      <h2 class="display">Looking is another way of writing things down.</h2>
      <a class="profile-image-link" href="/journal/the-shape-of-waiting/">
        View the photo essay <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="profile-work shell">
    <div class="profile-work-intro">
      <p class="eyebrow">Elsewhere</p>
      <h2 class="display">Three open doors.</h2>
    </div>
    <div class="profile-work-grid">
      <a href="https://thenarrativewitness.com">
        <span>The book</span>
        <strong>The Narrative Witness</strong>
        <p>
          The focused pre-launch home for the adoption, relinquishment and
          literary memoir project.
        </p>
      </a>
      <a href="https://jonathanlyon.substack.com">
        <span>The essays</span>
        <strong>Substack</strong>
        <p>
          Longer public writing on adoption, identity, memory, authorship and
          the work of becoming.
        </p>
      </a>
      <a href="/journal/">
        <span>The archive</span>
        <strong>Journal</strong>
        <p>
          The future home for field notes, photographs, fragments, moments and
          ordinary dispatches from the cabin and beyond.
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
